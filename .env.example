# Lions Club App - Environment Variables
# Copy this file to .env and fill in your values

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:pass@localhost:5432/lionsclub

# Session secret (long random string)
SESSION_SECRET=change-me-to-a-long-random-string

# SendGrid (Email)
SENDGRID_API_KEY=SG.xxx
SENDGRID_FROM_EMAIL=admin@deinclub.de

# OpenRouter (AI / Kurzbericht)
OPENROUTER_API_KEY=sk-or-v1-xxx

# External file upload server
WEBSERVER_UPLOAD_URL=https://deinserver.de/upload.php
WEBSERVER_UPLOAD_KEY=dein-upload-key

# App identity
BASE_URL=https://deinclub.de
APP_NAME="Lions Club Dein Club"

# Port (optional, defaults to 5000)
PORT=5000
